# ============================================================
# CONFIGURACIÓN DEL AGENTE - Upload Documents to Base de Conocimiento
# ============================================================
# Copia este archivo como .env y completa los valores requeridos.
# El agente leerá estos valores antes de procesar cualquier documento.

# ------------------------------------------------------------
# CAMPOS OBLIGATORIOS
# ------------------------------------------------------------

# Nombre del cliente al que pertenecen los documentos
CLIENTE=

# Nombre del proyecto al que pertenecen los documentos
PROYECTO=

# ------------------------------------------------------------
# CAMPOS OPCIONALES
# ------------------------------------------------------------

# Tipo de documento (opcional).
# Si se deja vacío, el agente inferirá el tipo de documento
# analizando el contenido de cada archivo y comparándolo
# contra la lista de tipos disponibles en la base de conocimiento.
#
# Valores posibles (consultar lista oficial en la base de conocimiento):
# Ejemplo: "Acta de Reunión", "Propuesta Comercial", "Manual Técnico",
#          "Requerimiento", "Minuta", "Informe", "Transcripción", etc.
TIPO_DOCUMENTO=

# ------------------------------------------------------------
# CONFIGURACIÓN MCP - Base de Conocimiento
# ------------------------------------------------------------

# Token de autenticación Bearer para el MCP de la Base de Conocimiento.
# Este valor se inyecta en mcp.json → headers.Authorization
BC_API_TOKEN=TU_TOKEN

# URL del servidor MCP (modificar solo si cambia el entorno)
BC_MCP_URL=https://dev-containerapp-knowledge-mcp.thankfuldune-a33f5cc2.eastus2.azurecontainerapps.io/mcp
